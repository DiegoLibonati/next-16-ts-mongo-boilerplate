# Stage 1 — install dependencies
FROM node:22-alpine AS deps

WORKDIR /home/app

COPY package*.json ./
RUN npm ci

# Stage 2 — build the app
FROM node:22-alpine AS builder

WORKDIR /home/app

COPY --from=deps /home/app/node_modules ./node_modules
COPY . .

RUN npm run build

# Stage 3 — production runner
FROM node:22-alpine AS runner

WORKDIR /home/app

ENV NODE_ENV=production
ENV HOSTNAME=0.0.0.0
ENV PORT=3000

RUN addgroup -S appgroup && adduser -S appuser -G appgroup

COPY --from=builder /home/app/.next/standalone ./
COPY --from=builder /home/app/.next/static ./.next/static
COPY --from=builder /home/app/public ./public

RUN chown -R appuser:appgroup /home/app

USER appuser

EXPOSE 3000

CMD ["node", "server.js"]
